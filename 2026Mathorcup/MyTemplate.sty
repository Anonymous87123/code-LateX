%=================  solution 环境（支持可选标签参数） =================%
\makeatletter
% 安全的页码提取宏
\newcommand*\boxpages[1]{%
  % 初始化变量
  \def\startpage{??}%
  \def\endpage{??}%
  \def\temp@start{0}%
  \def\temp@end{0}%
  
  % 尝试提取起始页码
  \ifcsname r@\detokenize{#1}\endcsname
    % 使用 \getpagerefnumber 获取页码
    \edef\temp@start{\getpagerefnumber{\detokenize{#1}}}%
    % 检查是否是有效的页码（大于0）
    \ifnum\temp@start>0\relax
      \edef\startpage{\temp@start}%
    \else
      \def\startpage{??}%
    \fi
  \fi
  
  % 尝试提取结束页码
  \ifcsname r@\detokenize{#1-end}\endcsname
    \edef\temp@end{\getpagerefnumber{\detokenize{#1-end}}}%
    \ifnum\temp@end>0\relax
      \edef\endpage{\temp@end}%
    \else
      \def\endpage{??}%
    \fi
  \fi
  
  % 输出页码范围（使用字符串比较）
  \def\temp@qmark{??}%
  \ifx\startpage\temp@qmark
    \ifx\endpage\temp@qmark
      ??%
    \else
      ??--\endpage
    \fi
  \else
    \ifx\endpage\temp@qmark
      \startpage\,??%
    \else
      % 都是有效数字，进行数值比较
      \ifnum\startpage=\endpage\relax
        p.\,\startpage
      \else
        pp.\,\startpage--\endpage
      \fi
    \fi
  \fi
}

% 处理带空格的标签
\newcommand{\safelabel}[1]{%
  \begingroup
  \edef\x{\endgroup\noexpand\label{\detokenize{#1}}}\x
}

% solution 环境 - 支持可选标签参数
\NewDocumentEnvironment{solution}{O{解} o}
  {%
    % 检查第二个参数是否提供了非空值
    \IfValueTF{#2}{%
      % 提供了第二个参数，检查是否为空值
      \def\@tmp@arg{#2}%
      \ifx\@tmp@arg\@empty
        % 空值：不分配标签
        \begin{tcolorbox}[
          breakable,
          colback  = gray!5,
          colframe = gray!80,
          colbacktitle = gray!80,
          coltitle = black,
          title    = {#1},
        ]%
      \else
        % 非空值：分配标签（支持空格和冒号）
        \begin{tcolorbox}[
          breakable,
          colback  = gray!5,
          colframe = gray!80,
          colbacktitle = gray!80,
          coltitle = black,
          title    = {#1},
          after    = {\safelabel{#2-end}},
        ]%
        \safelabel{#2}%
      \fi
    }{%
      % 没有提供第二个参数：不分配标签
      \begin{tcolorbox}[
        breakable,
        colback  = gray!5,
        colframe = gray!80,
        colbacktitle = gray!80,
        coltitle = black,
        title    = {#1},
      ]%
    }%
  }
  {\end{tcolorbox}}
\makeatother

