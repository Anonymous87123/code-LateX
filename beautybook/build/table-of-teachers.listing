  db_source=# CREATE PUBLICATION all_tables_pub FOR ALL TABLES;
  CREATE PUBLICATION

  -- 查看一下复制槽
  -- 订阅者连接到发布者并创建一个复制插槽
  -- 其信息在 pg_replication_slots 表中查看下
  db_source=# select * from pg_replication_slots;
  slot_name           | sub_all_tables
  plugin              | pgoutput
  slot_type           | logical
  datoid              | 17445
  database            | db_source
  temporary           | f
  active              | f
  active_pid          | ¤
  xmin                | ¤
  catalog_xmin        | 1452
  restart_lsn         | 0/75062A8
  confirmed_flush_lsn | 0/75062A8
  wal_status          | reserved
  safe_wal_size       | ¤
  two_phase           | f
  conflicting         | f

  -- 查看一下发布信息
  -- 当创建一个发布时，发布的信息可以从 pg_publication 表中查看
  db_source=# select * from pg_publication;
  -[ RECORD 1 ]+---------------
  oid          | 16395
  pubname      | all_tables_pub
  pubowner     | 10
  puballtables | t
  pubinsert    | t
  pubupdate    | t
  pubdelete    | t
  pubtruncate  | t
  pubviaroot   | f
