\NeedsTeXFormat{LaTeX2e}[1995/12/01]
% 定义宏包信息：路径、日期、版本（更新版本号）
\ProvidesPackage{stys/beautybook-cover-stargate}[2025/08/03,v1.0]
% 加载anyfontsize宏包，支持任意字体大小设置
\usepackage{anyfontsize} % 提供\fontsize{}{}\selectfont命令
% 加载etoolbox宏包，用于条件判断和自定义选项接口
\usepackage{etoolbox} %提供自定义封面选项接口
% 加载xcolor宏包，支持多种颜色命名系统
\usepackage[dvipsnames,svgnames,x11names,table]{xcolor}%颜色宏包
% 加载tikz宏包用于绘图
\usepackage{tikz}
% 加载tikz所需库（保留核心库，新增装饰库）
\usetikzlibrary{intersections, positioning, fit, backgrounds, shapes, fadings,
	decorations.pathmorphing, decorations.pathreplacing, calc} % 替换为装饰路径库
% 加载插图宏包
\usepackage{graphicx} %插图
% 加载tikz补充库
\usetikzlibrary{calc,fadings,patterns}
% 加载调整盒子对齐的宏包
\usepackage{adjustbox} %修正minipage顶部对齐问题

% 定义图层（保持原有图层结构）
\pgfdeclarelayer{background} % 背景层（底层）
\pgfdeclarelayer{foreground} % 前景层（上层）
\pgfdeclarelayer{top} % 顶层
\pgfdeclarelayer{bottom} % 底层
\pgfsetlayers{bottom,background,main,foreground,top} % 图层顺序不变

% 重新定义颜色系统（改为蓝紫渐变系）
\definecolor{PRIMARY}{HTML}{0f2540} % 主色：深紫蓝
\definecolor{SECONDARY}{HTML}{005caf} % 辅助色：中紫蓝
\definecolor{ACCENT}{HTML}{2b5f75} % 强调色：浅紫蓝
\definecolor{arc color}{HTML}{9B8AFA} % 弧线颜色：淡紫蓝

% 重新定义渐隐效果（调整透明度参数）
\tikzfading[name=fade right,right color=transparent!100,left color=transparent!30] % 右侧更透明
\tikzfading[name=fade left,left color=transparent!100,right color=transparent!30]
\tikzfading[name=fade up,top color=transparent!100,bottom color=transparent!30]
\tikzfading[name=fade down,bottom color=transparent!100,top color=transparent!30]
% /* -------------------------------------------------------------------------- */
\makeatletter
\newcommand{\aivcover}{
    \begin{tikzpicture}[remember picture,overlay]
            % 底层背景（替换为新几何图形）
		\begin{pgfonlayer}{bottom}
			\node[inner sep=0pt] at (current
page.center){\includegraphics[width=\paperwidth,height=\paperheight]{\@coverimage}};
			% 背景色改为主色渐变
			\shade[left color=PRIMARY!90,right color=SECONDARY!80,opacity=0.85]
			(current page.north west) rectangle (current page.south east);% 新背景渐变
			
			% 右上角几何图形装饰
			\begin{scope}[shift={([shift={(-5cm,-5cm)}]current page.north east)}, scale=2.5, opacity=0.7,rotate=15]
				% 大圆
				\draw[ACCENT!50, line width=1.5pt] (0,0) circle (1.5cm);
				
				% 内接三角形
				\draw[ACCENT!70, line width=1.2pt] 
				(0:1.2cm) -- (120:1.2cm) -- (240:1.2cm) -- cycle;
				
				% 放射线
				\foreach \angle in {0,30,...,330} {
					\draw[ACCENT!40, line width=0.8pt] (0,0) -- (\angle:1.8cm);
				}
				
				% 装饰小圆
				\foreach \angle in {0,60,...,300} {
					\fill[ACCENT!60] (\angle:1.8cm) circle (0.08cm);
				}
			\end{scope}
			
			% 右侧波浪线装饰（保留）
			\draw[decorate, decoration={snake, amplitude=1cm, segment length=3cm},
			line width=2pt, ACCENT!50, opacity=0.6]
			([shift={(0,-5cm)}]current page.north east) -- (current page.south east);% 右侧波浪线
			
			% 左侧垂直渐变条（保留）
			\shade[top color=ACCENT!60,bottom color=PRIMARY!60]
			(current page.north west) rectangle ([shift={(1.5cm,0)}]current page.south west);% 左侧渐变条
		\end{pgfonlayer}
		
		% 前景装饰（修改为圆形点阵）
		\begin{pgfonlayer}{foreground}
			\foreach \r in {0.3,0.6,...,4} { % 多个同心圆
				\draw[circle, radius=\r cm, SECONDARY!40, line width=1pt, opacity=0.5,dotted]
				($(current page.center) + (3cm,-5cm)$) circle (\r cm); % 中心定位
			}
			% 替换原装饰条为渐变矩形
			\shade[left color=ACCENT!70,right color=PRIMARY!70,opacity=0.5]
			([yshift=2\outermarginwidth]current page.west) rectangle 
			([xshift=\outermarginwidth,yshift=-.2\outermarginwidth]current page.west);% 左侧装饰条
		\end{pgfonlayer}

            \shade[left color=PRIMARY!60,right color=SECONDARY!50,opacity=.4]
                ([xshift=\outermarginwidth,yshift=2\outermarginwidth]current page.west) rectangle (current page.south east); % 标题背景大矩形
            \node[anchor=south] at ([xshift=.3\outermarginwidth,yshift=-.4\covershift]current page.north) {%
                \parbox{.8\paperwidth}{
                \filright
                \color{white}\sffamily\fontsize{20}{23}\selectfont\@bookseries}
            }; %系列丛书名称
            \node[ anchor=south,below right] (covertitles) at ([xshift=1.8\outermarginwidth-0.2cm,yshift=2.7cm]current page.west)
            {\parbox{.8\paperwidth}{%
                \raggedright%
                {\renewcommand\baselinestretch{1.1}\selectfont           \color{white}\sffamily\bfseries\fontsize{40}{40}\selectfont\@title\\[0.5ex]
                    \color{white}\sc\fontsize{30}{30}\selectfont
                    \ifdefvoid{\@subtitle}{}{\@subtitle}\par}
            }};% 封面标题与副标题
            \node[anchor=west,font=\sc\fontsize{23}{23}\selectfont,text=white] at ([shift={(-.4\paperwidth,-6cm)}]covertitles) {\@edition};
            \node[anchor=west,font=\sffamily\Huge,text=white] at ([xshift=1.8\outermarginwidth-0.3cm,yshift=\covershift]current page.west) {\@author};
            \node[left,text=white!90,font=\rmfamily\Large,] at
                ([shift={(-2cm,2cm)}]current page.south east) 
                {\raisebox{-0.5cm}{\includegraphics[width=0.1\linewidth]{\@presslogo}}\hspace*{0ex}\begin{varwidth}{.4\textwidth}\tikz\draw[white!70,line width=1.25pt] (0,0)--++(0,1cm);\,\raisebox{.25cm}{\@pressname} \end{varwidth}};%
\end{tikzpicture}%
}

