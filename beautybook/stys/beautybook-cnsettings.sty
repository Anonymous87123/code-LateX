% /* ------------------------------- 第三套定理系统定制窗口 ------------------------------ */
\RequirePackage{iftex}
% /* -------------------------------------------------------------------------- */
% Definition
\definecolor{defcolor}{HTML}{522f60}
\newkeytheoremstyle{defstyle}
{
    headfont=\normalfont\scshape\bfseries,
    notefont=\normalfont\bfseries,
    notebraces={(}{)},  % chktex 9
    headpunct={.},
    bodyfont=\normalfont,
    headformat=\NAME~\NUMBER~\NOTE,
    break,
    tcolorbox={
            thmstyle,
            thm color=defcolor,
            thm title color=black,
            thm back color=defcolor,
        }
}
\ifxetex
    \newkeytheorem{Definition}[
        Refname={Definition,Definitions},
        style=defstyle,
        numberwithin=chapter,
        name=定义,
    ]
\else
    \newkeytheorem{Definition}[
        Refname={Definition,Definitions},
        style=defstyle,
        numberwithin=chapter,
        name=Definition,
    ]
\fi
% Theorem
\definecolor{theocolor}{RGB}{237, 138, 130}
\newkeytheoremstyle{theoremstyle}
{
   headfont=\normalfont\scshape\bfseries,
   notefont=\normalfont\bfseries,
   notebraces={(}{)},  % chktex 9
   headpunct={.},
   bodyfont=\normalfont,
   headformat=\NAME~\NUMBER~\NOTE,
   % break,
   tcolorbox={
         thmstyle,
         thm color=purple,
         thm title color=black,
         thm back color=purple,
      }
}
\ifxetex
   \newkeytheorem{Theorem}[
      Refname={Theorem,Theorems},
      style=theoremstyle,
      sibling=Definition,
      name=定理,
   ]
\else
   \newkeytheorem{Theorem}[
      Refname={Theorem,Theorems},
      style=theoremstyle,
      sibling=Definition,
      name=Theorem,
   ]
\fi
% Corollary
\definecolor{corcolor}{HTML}{eb6238}
\newkeytheoremstyle{corstyle}
{
    headfont=\normalfont\scshape\bfseries,
    notefont=\normalfont\bfseries,
    notebraces={(}{)},  % chktex 9
    headpunct={.},
    bodyfont=\normalfont,
    headformat=\NAME~\NUMBER~\NOTE,
    % break,
    tcolorbox={
            thmstyle,
            thm color=corcolor,
            thm title color=black,
            thm back color=corcolor,
        }
}
\ifxetex
    \newkeytheorem{Corollary}[
        Refname={Corollary,Corollaries},
        style=corstyle,
        sibling=Definition,
        name=推论,
    ]
\else 
    \newkeytheorem{Corollary}[
        Refname={Corollary,Corollaries},
        style=corstyle,
        sibling=Definition,
        name=Corollary,
    ]
\fi
% Lemma
\definecolor{lemmacolor}{HTML}{2f5d50}
\newkeytheoremstyle{lemmastyle}
{
    headfont=\normalfont\scshape\bfseries,
    notefont=\normalfont\bfseries,
    notebraces={(}{)},  % chktex 9
    headpunct={.},
