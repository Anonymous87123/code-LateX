% proof
\newcommand{\itbf}[1]{\textit{\textbf{#1}}}
\declaretheoremstyle[
  spaceabove=3pt,spacebelow=3pt,
  headfont=\normalfont\bfseries,
  notefont=\normalfont\bfseries,notebraces={(}{)},
  bodyfont=\normalfont,
  postheadspace=.5em,
  headpunct={.},
  qed=\color{cyan!40!black}$\blacksquare$,%\qedsymbol
]{Proofstyle}
\declaretheorem[style=Proofstyle,numbered=no,name={\itbf{Proof}}]{Proof}
\renewenvironment{proof}{\begin{Proof} }{\end{Proof}}
\declaretheorem[style=Proofstyle,numbered=no,name={\itbf{Solution}}]{solution}
%
% /* ------------------------------- 第三套定理系统定制窗口 ------------------------------ */
\RequirePackage{iftex}
% /* -------------------------------------------------------------------------- */
% Definition
\definecolor{defcolor}{HTML}{522f60}
\newkeytheoremstyle{defstyle}
{
    headfont=\normalfont\scshape\bfseries,
    notefont=\normalfont\bfseries,
    notebraces={(}{)},  % chktex 9
    headpunct={.},
    bodyfont=\normalfont,
    headformat=\NAME~\NUMBER~\NOTE,
    break,
    tcolorbox={
            thmstyle,
            thm color=defcolor,
            thm title color=black,
            thm back color=defcolor,
        }
}
\ifxetex
    \newkeytheorem{Definition}[
        Refname={Definition,Definitions},
        style=defstyle,
        numberwithin=chapter,
        name=定义,
    ]
\else
    \newkeytheorem{Definition}[
        Refname={Definition,Definitions},
        style=defstyle,
        numberwithin=chapter,
        name=Definition,
    ]
\fi
% Theorem
\definecolor{theocolor}{RGB}{237, 138, 130}
\newkeytheoremstyle{theoremstyle}
{
   headfont=\normalfont\scshape\bfseries,
   notefont=\normalfont\bfseries,
   notebraces={(}{)},  % chktex 9
   headpunct={.},
   bodyfont=\normalfont,
   headformat=\NAME~\NUMBER~\NOTE,
   % break,
   tcolorbox={
         thmstyle,
         thm color=purple,
         thm title color=black,
         thm back color=purple,
      }
}
\ifxetex
   \newkeytheorem{Theorem}[
      Refname={Theorem,Theorems},
      style=theoremstyle,
      sibling=Definition,
      name=定理,
   ]
\else
   \newkeytheorem{Theorem}[
      Refname={Theorem,Theorems},
      style=theoremstyle,
      sibling=Definition,
      name=Theorem,
   ]
\fi
% Corollary
\definecolor{corcolor}{HTML}{eb6238}
\newkeytheoremstyle{corstyle}
{
    headfont=\normalfont\scshape\bfseries,
    notefont=\normalfont\bfseries,
    notebraces={(}{)},  % chktex 9
    headpunct={.},
    bodyfont=\normalfont,
    headformat=\NAME~\NUMBER~\NOTE,
    % break,
    tcolorbox={
            thmstyle,
            thm color=corcolor,
            thm title color=black,
            thm back color=corcolor,
        }
}
\ifxetex
    \newkeytheorem{Corollary}[
        Refname={Corollary,Corollaries},
        style=corstyle,
        sibling=Definition,
        name=推论,
    ]
\else 
    \newkeytheorem{Corollary}[
        Refname={Corollary,Corollaries},
        style=corstyle,
        sibling=Definition,
        name=Corollary,
    ]
\fi
% Lemma
\definecolor{lemmacolor}{HTML}{2f5d50}
\newkeytheoremstyle{lemmastyle}
{
    headfont=\normalfont\scshape\bfseries,
    notefont=\normalfont\bfseries,
    notebraces={(}{)},  % chktex 9
    headpunct={.},
    bodyfont=\normalfont,
    break,
    headformat=\NAME~\NUMBER~\NOTE,
    tcolorbox={
            thmstyle,
            thm color=lemmacolor,
            thm title color=black,
            thm back color=lemmacolor,
        }
}
\ifxetex
    \newkeytheorem{Lemma}[
        Refname={Lemma,Lemmata},
        style=lemmastyle,
        sibling=Definition,
        name=引理,
    ]
\else 
    \newkeytheorem{Lemma}[
        Refname={Lemma,Lemmata},
        style=lemmastyle,
        sibling=Definition,
        name=Lemma,
    ]
\fi
% Proof
\newkeytheoremstyle{proofstyle}
{
    headfont=\normalfont\itshape,
    notebraces={}{},
    headpunct={.},
    bodyfont=\normalfont,
    headformat=\NAME\NOTE,
    spaceabove = 0pt,
    qed
}
\ifxetex
    \renewkeytheorem{Proof}[
        Refname={Proof,Proofs},
        style=proofstyle,
        name=\sffamily\bfseries{}证明,
    ]
    \newkeytheorem{Solution}[
        Refname={Solution,Solutions},
        style=proofstyle,
        name=\sffamily\bfseries{}解,
    ]
\else
    \renewkeytheorem{Proof}[
        Refname={Proof,Proofs},
        style=proofstyle,
        name=\sffamily\bfseries{}Proof,
    ]
    \newkeytheorem{Solution}[
        Refname={Solution,Solutions},
        style=proofstyle,
        name=\sffamily\bfseries{}Solution,
    ]
\fi
