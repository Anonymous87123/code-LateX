  411:     for i in range(1, len(prefix)):
  358:         idx = table[i - 1]
  370:         while prefix[i] != prefix[idx]:
  353:             if idx == 0:
  341:                 table[i] = 0
  341:                 break
   12:             idx = table[idx - 1]
               else:
   17:             table[i] = idx + 1
   53:     return table
       
