  114:     comps = {}
  114:     mapping = bytearray(256)
  114:     block = 0
  114:     data = bytearray()
29298:     for i in range(0, 65536, 256):
29184:         chunk = charmap[i: i + 256]
29184:         if chunk in comps:
28650:             mapping[i // 256] = comps[chunk]
