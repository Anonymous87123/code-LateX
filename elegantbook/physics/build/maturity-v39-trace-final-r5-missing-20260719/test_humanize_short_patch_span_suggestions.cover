    1: def load_module(name: str, path: Path):
    1:     spec = importlib.util.spec_from_file_location(name, path)
    1:     assert spec is not None and spec.loader is not None
    1:     module = importlib.util.module_from_spec(spec)
    1:     sys.modules[name] = module
    1:     spec.loader.exec_module(module)
    1:     return module
       
       
