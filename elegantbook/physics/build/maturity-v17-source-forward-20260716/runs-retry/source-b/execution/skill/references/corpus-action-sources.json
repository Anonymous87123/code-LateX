{"action_cards":[{"action":"Reject repeated model-generated meta-question contrasts and self-validating closures that narrate what a section should prove instead of letting the evidence carry the paragraph.","detector":{"minimum_groups":1,"pattern_groups":[{"id":"repeated_meta_answer","minimum_occurrences":2,"regex":"(?:真正要回答的不是|核心不是|更关注[^。；！？!?]{0,40}而不是)"},{"id":"repeated_self_validating_close","minimum_occurrences":2,"regex":"(?:这样处理(?:后)?|也正因为如此|这样一来)[^。；！？!?]{0,80}(?:更符合|就会|才能|足以|完成)"}]},"forbids":["repeated 不是/而是 section framing","automatic 这样处理 closure","using model-generated prose as a positive action source"],"id":"NEGATIVE-RESEARCH-MAIN-META-SHELL-01","kind":"negative_guard","required_anchor_roles":["template"],"requires":["repeated meta-question contrast or automatic closure"],"scene":"RESEARCH","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-MAIN-TEX"}]},{"action":"Reject a repeated fixed chain that forces a surface explanation, deeper mechanism, balanced limitation, and aspirational closure into unrelated paragraphs.","detector":{"minimum_groups":1,"pattern_groups":[{"id":"future_bridge","minimum_occurrences":1,"regex":"(?:为|给|供)(?:后续|未来)(?:研究|分析|检验|工作|探索)?.{0,12}(?:提供|奠定|打下|形成).{0,12}(?:基础|支撑|线索|参考|依据|方向)"},{"id":"repeated_forced_contrast","minimum_occurrences":2,"regex":"不是[^。；！？!?]{1,80}?而是"}]},"forbids":["automatic escalation","forced contrast","automatic future bridge","synonym-only variation"],"id":"NEGATIVE-TEMPLATE-01","kind":"negative_guard","required_anchor_roles":["template"],"requires":["repeated paragraph-level structural pattern"],"scene":"ALL","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-CET6-TEMPLATE-NEGATIVE"}]},{"action":"Reject a repeated algorithm README shell that substitutes headings and promotional advantages for a manuscript argument.","detector":{"minimum_groups":1,"pattern_groups":[{"id":"readme_headings","minimum_occurrences":3,"regex":"(?m)^(?:#{1,6}|\\\\(?:sub)*section\\{)[^\\n}]*(?:核心特点|分组流程|主要优势|机制说明|复杂度)[^\\n}]*\\}?"},{"id":"promotional_adjectives","minimum_occurrences":3,"regex":"(?:高效|准确|全面|显著降低|鲁棒|无参数自适应)"}]},"forbids":["definition-features-stages-advantages-mechanism-complexity shell","ungrounded efficiency or robustness adjectives"],"id":"NEGATIVE-MODELING-README-SHELL-01","kind":"negative_guard","required_anchor_roles":["template"],"requires":["repeated README-like heading family or promotional claim cluster"],"scene":"MODELING","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-MODELING-README-SHELL"}]},{"action":"Reject construction-plan and implementation-order language when it appears in finished modeling prose.","detector":{"minimum_groups":1,"pattern_groups":[{"id":"construction_plan_terms","minimum_occurrences":3,"regex":"(?:总编施工图|数据锚点|最终模型结构|代码实现顺序|论文写法|先读结论)"}]},"forbids":["chief-editor construction voice","code implementation order in manuscript prose","data-anchor task list as a result section"],"id":"NEGATIVE-MODELING-CONSTRUCTION-PLAN-01","kind":"negative_guard","required_anchor_roles":["template"],"requires":["planning-language cluster"],"scene":"MODELING","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-MODELING-CONSTRUCTION-PLAN"}]},{"action":"Reject governance, acceptance, and repeated final-judgment voice in ordinary academic prose.","detector":{"minimum_groups":2,"pattern_groups":[{"id":"governance_state","minimum_occurrences":2,"regex":"(?:收口|闭环|主链路|完成度)"},{"id":"final_judgment","minimum_occurrences":1,"regex":"(?:最终(?:强化判断|自检|结论)|最后一句(?:总)?判断|最值得记住的一句话)"},{"id":"risk_register","minimum_occurrences":2,"regex":"(?:风险项|风险\\s*[A-ZＡ-Ｚ一二三四五六七八九十])"}]},"forbids":["closure and main-chain language","risk-register substitution for argument","repeated final acceptance judgment"],"id":"GENERAL-NEG-GOVERNANCE-VOICE","kind":"negative_guard","required_anchor_roles":["template"],"requires":["at least two governance-voice clusters"],"scene":"GENERAL","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-GOVERNANCE"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-GOVERNANCE"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-GOVERNANCE"}]},{"action":"Reject automatic promotion of GENERAL prose into a journal-defense shell with contribution lists and routine future work.","detector":{"minimum_groups":2,"pattern_groups":[{"id":"contribution_heading","minimum_occurrences":1,"regex":"(?:主要贡献如下|本文的主要贡献)"},{"id":"future_work","minimum_occurrences":1,"regex":"(?:未来|后续)(?:研究|工作)(?:可|将|需要|可以)?进一步"},{"id":"defensive_contrast","minimum_occurrences":2,"regex":"不是[^。；！？!?]{1,80}?而是"}]},"forbids":["abstract-contribution-defense-future-work shell","automatic reviewer-defense contrast","routine three-item outlook"],"id":"GENERAL-NEG-RESEARCH-JOURNAL-OVERFIT","kind":"negative_guard","required_anchor_roles":["template"],"requires":["at least two journal-shell clusters"],"scene":"GENERAL","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-JOURNAL-OVERFIT"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-JOURNAL-OVERFIT"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-JOURNAL-OVERFIT"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-JOURNAL-OVERFIT"}]},{"action":"Reject product-application claim stacks that compress problems, features, scale, efficiency, and deliverables into promotional density.","detector":{"minimum_groups":2,"pattern_groups":[{"id":"core_claim","minimum_occurrences":1,"regex":"(?:核心是解决|核心逻辑流|核心在于解决)"},{"id":"promotional_metrics","minimum_occurrences":3,"regex":"(?:\\d+(?:\\.\\d+)?(?:\\+|%|％)|\\d+\\s*[-–—]\\s*\\d+%)"},{"id":"application_labels","minimum_occurrences":2,"regex":"(?:硬信息|深度参与|完整闭环|效率提升)"}]},"forbids":["core-logic marketing shell","dense unsupported scale numbers","hard-information repetition after prose"],"id":"GENERAL-NEG-PROMOTIONAL-CLAIM-STACK","kind":"negative_guard","required_anchor_roles":["template"],"requires":["at least two promotional clusters"],"scene":"GENERAL","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-PROMOTIONAL"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-PROMOTIONAL"}]},{"action":"Reject rumor, emotional judgment, or mobilizing commands when they substitute for academic evidence.","detector":{"minimum_groups":1,"pattern_groups":[{"id":"rumor_or_certainty","minimum_occurrences":1,"regex":"(?:据说|半官方消息|不争的事实|大概率)"},{"id":"emotional_judgment","minimum_occurrences":1,"regex":"(?:危害无穷|令人心痛|必须淘汰)"},{"id":"mobilizing_command","minimum_occurrences":2,"regex":"(?:(?:考生|学生|大家|我们|你|读者)[^。！？\\n]{0,12}?(?:必须|务必|一定要)|(?:必须|务必|一定要)[^。！？\\n]{0,12}?(?:牢记|记住|掌握|坚持|做到|避免|警惕|高度重视|积极行动))"}]},"forbids":["rumor as evidence","opinion stated as universal fact","mobilizing or blessing-style close"],"id":"GENERAL-NEG-OPINION-AS-EVIDENCE","kind":"negative_guard","required_anchor_roles":["template"],"requires":["unsupported-attribution, emotional-judgment, or command cluster"],"scene":"GENERAL","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-OPINION"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-OPINION"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-OPINION"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-OPINION"}]},{"action":"Reject OCR-damaged textbook Q&A and memorization-note structure as a positive academic prose model.","detector":{"minimum_groups":2,"pattern_groups":[{"id":"dense_enumeration","minimum_occurrences":5,"regex":"(?m)^\\s*(?:\\d+[.、]|[（(]\\d+[）)])"},{"id":"question_answer_markers","minimum_occurrences":3,"regex":"(?:答[:：]|为什么|如何理解|怎样做)"}]},"forbids":["OCR repair guessing","exam-answer enumeration","textbook memorization couplets as continuous argument"],"id":"GENERAL-NEG-OCR-AND-TEXTBOOK","kind":"negative_guard","required_anchor_roles":["template"],"requires":["dense enumeration plus Q&A marker cluster"],"scene":"GENERAL","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-OCR-TEXTBOOK"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-OCR-TEXTBOOK"}]},{"action":"Reject API-documentation columns and navigation structure when they replace continuous academic explanation.","detector":{"minimum_groups":1,"pattern_groups":[{"id":"api_heading_family","minimum_occurrences":3,"regex":"(?m)^#{1,6}\\s*(?:概述|API\\s*参考|使用示例|高级用法|参考文献|下一页)"}]},"forbids":["bilingual heading mirror","API reference skeleton","navigation ending in academic prose"],"id":"GENERAL-NEG-API-TEMPLATE","kind":"negative_guard","required_anchor_roles":["template"],"requires":["dense API heading family"],"scene":"GENERAL","source_refs":[{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-API"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-API"},{"line_end":1,"line_start":1,"source_id":"SOURCE-NEG-GENERAL-API"}]}],"global_copy_limit":{"max_contiguous_han_chars":7,"rule":"Source material may inform an editing action only. Do not reuse eight or more contiguous Chinese characters from a source in a candidate rewrite."},"purpose":"Generator projection detector-only registry. Positive actions, external paths, source provenance, source tiers, and reusable source prose are absent.","schema_version":2,"sources":[{"id":"SOURCE-MAIN-TEX","origin_class":"MODEL_GENERATED","path":"corpus-action-sources.json","role":"negative_template_reference","scene_scope":["RESEARCH"],"source_tier":"DETECTOR_ONLY"},{"id":"SOURCE-CET6-TEMPLATE-NEGATIVE","origin_class":"MODEL_GENERATED","path":"corpus-action-sources.json","role":"negative_template_reference","scene_scope":["ALL"],"source_tier":"DETECTOR_ONLY"},{"id":"SOURCE-NEG-MODELING-README-SHELL","origin_class":"UNKNOWN","path":"corpus-action-sources.json","role":"negative_template_reference","scene_scope":["ALL","MODELING"],"source_tier":"DETECTOR_ONLY"},{"id":"SOURCE-NEG-MODELING-CONSTRUCTION-PLAN","origin_class":"MODEL_ORIGIN_UNRESOLVED","path":"corpus-action-sources.json","role":"negative_t