    2:     @staticmethod
    2:     def available(payload: dict, kind: str | None = None) -> list[dict]:
   58:         return [
  154:             item
  153:             for item in payload["span_suggestions"]
   95:             if item["status"] == "AVAILABLE"
   59:             and (kind is None or item["kind"] == kind)
               ]
       
    2:     @staticmethod
    2:     def suppressed(payload: dict, kind: str | None = None) -> list[dict]:
   36:         return [
  118:             item
