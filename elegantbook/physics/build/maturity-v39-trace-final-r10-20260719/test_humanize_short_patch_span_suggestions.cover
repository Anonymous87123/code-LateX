    1:         self.assertEqual(span["source_text"].encode("utf-8"), selected)
    2:         self.assertFalse(
    1:             suggestion["start_byte"] > 0
    2:             and raw[suggestion["start_byte"] - 1 : suggestion["start_byte"] + 1]
    1:             == b"\r\n"
