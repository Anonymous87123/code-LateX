{"guards":[{"detector":{"minimum_groups":2,"pattern_groups":[{"id":"core_claim","minimum_occurrences":1,"regex":"(?:核心是解决|核心逻辑流|核心在于解决)"},{"id":"promotional_metrics","minimum_occurrences":3,"regex":"(?:\\d+(?:\\.\\d+)?(?:\\+|%|％)|\\d+\\s*[-–—]\\s*\\d+%)"},{"id":"application_labels","minimum_occurrences":2,"regex":"(?:硬信息|深度参与|完整闭环|效率提升)"}]},"id":"GENERAL-NEG-PROMOTIONAL-CLAIM-STACK","scene":"GENERAL"},{"detector":{"minimum_groups":1,"pattern_groups":[{"id":"construction_plan_terms","minimum_occurrences":3,"regex":"(?:总编施工图|数据锚点|最终模型结构|代码实现顺序|论文写法|先读结论)"}]},"id":"NEGATIVE-MODELING-CONSTRUCTION-PLAN-01","scene":"MODELING"},{"detector":{"minimum_groups":1,"pattern_groups":[{"id":"repeated_meta_answer","minimum_occurrences":2,"regex":"(?:真正要回答的不是|核心不是|更关注[^。；！？!?]{0,40}而不是)"},{"id":"repeated_self_validating_close","minimum_occurrences":2,"regex":"(?:这样处理(?:后)?|也正因为如此|这样一来)[^。；！？!?]{0,80}(?:更符合|就会|才能|足以|完成)"}]},"id":"NEGATIVE-RESEARCH-MAIN-META-SHELL-01","scene":"RESEARCH"},{"detector":{"minimum_groups":1,"pattern_groups":[{"id":"future_bridge","minimum_occurrences":1,"regex":"(?:为|给|供)(?:后续|未来)(?:研究|分析|检验|工作|探索)?.{0,12}(?:提供|奠定|打下|形成).{0,12}(?:基础|支撑|线索|参考|依据|方向)"},{"id":"repeated_forced_contrast","minimum_occurrences":2,"regex":"不是[^。；！？!?]{1,80}?而是"}]},"id":"NEGATIVE-TEMPLATE-01","scene":"ALL"}],"registry_id":"humanize-academic-chinese/corpus-negative-guards/v1","schema_version":"humanize-negative-guard-registry/v1"}
