  "focus_spans": [
    {
      "end_byte": 343,
      "focus_id": "F001",
      "source_text": "**项目定位应是",
      "source_text_sha256": "7f1b366ab84f13a3cc091a473bac1489abdcf29993560388276c8d0517ef5811",
      "start_byte": 323
    },
    {
      "end_byte": 448,
      "focus_id": "F002",
      "source_text": "** ",
      "source_text_sha256": "06efaba3327c26fc7a8022ef20690499dcf1bbd1649a58f72d79a5837beac64c",
      "start_byte": 445
    },
    {
      "end_byte": 995,
      "focus_id": "F003",
      "source_text": "**零新增FE主线与主动数学确认分支必须分账。** ",
      "source_text_sha256": "883ac5582eac67649f7bfc14610dfff7fdbd4ffb8f56818da25ec27996e4b71c",
      "start_byte": 931
    },
    {
      "end_byte": 1221,
      "focus_id": "F004",
      "source_text": "只能作为低置信样例的预算受控确认",
      "source_text_sha256": "ae741431f00a688401727b1f037e0945fbfda9b38e61617f764a5b22f10f54d5",
      "start_byte": 1173
    },
    {
      "end_byte": 1380,
      "focus_id": "F005",
      "source_text": "**主输出应服务于决策，而非强行恢复完整交互图。** ",
      "source_text_sha256": "b091a7e7ceb2ee26826609aef10bc38a64d85766420b1876362fba2a3574713c",
      "start_byte": 1309
    },
    {
      "end_byte": 1758,
      "focus_id": "F006",
      "source_text": "**Loss不能只使用期望类别距离。** ",
      "source_text_sha256": "f41bea3cb655db4152102cfc498bcfd17ca9d1bb3246e9c3123c0b9690fdc010",
      "start_byte": 1713
    },
    {
      "end_byte": 2146,
      "focus_id": "F007",
      "source_text": "**最终价值必须用下游总收益验收。** ",
      "source_text_sha256": "55870fde443a2cd62a68e26d05f3e86a6c23ec54ebf70a277c513e97b67414e7",
      "start_byte": 2096
    },
    {
      "end_byte": 2158,
      "focus_id": "F008",
      "source_text": "统一比较",
      "source_text_sha256": "f5152135ed49fa23c8b4b39e991fa4f8c40b641e4ea4f88b25fa285c053d4c12",
      "start_byte": 2146
    },
    {
      "end_byte": 2789,
      "focus_id": "F009",
      "source_text": "同时满足样本顺序和坐标顺序不变",
      "source_text_sha256": "9f1b1bc55eb9fa3969c6741a339645b80685bebf561009b954b2920f84818d8a",
      "start_byte": 2744
    },
    {
      "end_byte": 3815,
      "focus_id": "F010",
      "source_text": "输出路由动作与依据；按共享总预算比较最终目标值，不只比较分类准确率",
      "source_text_sha256": "73150cc9ffbb0fe4923495f048f9159874131a18e6ffe386aa636a5f50c3c185",
      "start_byte": 3716
    }
  ],
