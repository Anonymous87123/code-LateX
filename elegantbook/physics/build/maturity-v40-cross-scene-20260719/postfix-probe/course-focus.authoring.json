  "focus_spans": [
    {
      "end_byte": 135,
      "focus_id": "F001",
      "source_text": "因此，",
      "source_text_sha256": "00594de27a30b7fc2f641c1c839368f5e95d7ff9b20c07c16443a4c8d9c61827",
      "start_byte": 126
    },
    {
      "end_byte": 430,
      "focus_id": "F002",
      "source_text": "乘积求导法则：",
      "source_text_sha256": "9ae31d372d7bd3b1c9758a7228128a90b9a3c508d0dcd754758706e3f198d81f",
      "start_byte": 409
    },
    {
      "end_byte": 935,
      "focus_id": "F003",
      "source_text": "，接下来我们需要求出 ",
      "source_text_sha256": "9e7930bba4f9c09a4a00e3f95cdad953bef053f2e3a56b894526f0204ec4693f",
      "start_byte": 904
    },
    {
      "end_byte": 999,
      "focus_id": "F004",
      "source_text": " 具体等于什么。",
      "source_text_sha256": "259b0a72125e5ff13937078f5aaf3ecc08d474696e69b6fd0b0411df27d2e707",
      "start_byte": 977
    },
    {
      "end_byte": 1027,
      "focus_id": "F005",
      "source_text": "为了看清 ",
      "source_text_sha256": "1a05f872404b6c6015ad39cbf8c7824adea206c2f907e93ab1c171160bd94e72",
      "start_byte": 1014
    },
    {
      "end_byte": 1093,
      "focus_id": "F006",
      "source_text": " 的几何本质，我们引入路程微元 ",
      "source_text_sha256": "ea5559f4cc62c69540faf594ecf190f32e3a00444f45971e5f5c7dd212cbd264",
      "start_byte": 1049
    },
    {
      "end_byte": 1144,
      "focus_id": "F007",
      "source_text": " 进行链式展开，提取出速率 ",
      "source_text_sha256": "3c2074d2b950b8d834d38d3333d9fe2e6549d6fb62ed8d4013816419be1fc35f",
      "start_byte": 1106
    },
    {
      "end_byte": 1376,
      "focus_id": "F008",
      "source_text": " 时间内走过了弧长 ",
      "source_text_sha256": "2c11bda56eba7ca9f60dffc3149a578b9382a9960d2a93e4c9c5db4c5b8a88e8",
      "start_byte": 1350
    },
    {
      "end_byte": 1423,
      "focus_id": "F009",
      "source_text": "。对应的切向单位矢量从 ",
      "source_text_sha256": "ae17615eb14b12c8a3390b012595a738f6326c2c5eee91bcbbb17cb4655894d0",
      "start_byte": 1389
    },
    {
      "end_byte": 1446,
      "focus_id": "F010",
      "source_text": " 变到了 ",
      "source_text_sha256": "96790db5f028ea6a8bb45a37b149f7c5dba561a6934df5a3ce5e51e839b9702f",
      "start_byte": 1435
    },
    {
      "end_byte": 1910,
      "focus_id": "F011",
      "source_text": "，也就是法向单位矢量 ",
      "source_text_sha256": "f721fddd89877388ae66eafff48df956325f67b820f1cda8aa9115ba2de20fb4",
      "start_byte": 1879
    },
    {
      "end_byte": 2277,
      "focus_id": "F012",
      "source_text": "根据数学上对轨道曲率半径 ",
      "source_text_sha256": "2e093eaabf069b75582c2e2a6ac55a1dfb3afbd348dcf229f19ac1f1190c1104",
      "start_byte": 2240
    },
    {
      "end_byte": 2506,
      "focus_id": "F013",
      "source_text": "代入前面的大小公式，得到：",
      "source_text_sha256": "88ec3b017184fae94638cfa6b4ecf426068547b779e9225ebe04f79aa39b27c0",
      "start_byte": 2467
    },
    {
      "end_byte": 2661,
      "focus_id": "F014",
      "source_text": "我们可以写出 ",
      "source_text_sha256": "a31741707190861caf83e62082a60e7ad0233a7056fed0dcef63345f2b35ea48",
      "start_byte": 2642
    },
    {
      "end_byte": 2859,
      "focus_id": "F015",
      "source_text": "现在，把 ",
      "source_text_sha256": "6eda0e88447d001ff083aeebebc7e4716e8d8db6372d9abef9fd6c650c9ec504",
      "start_byte": 2846
    },
    {
      "end_byte": 2959,
      "focus_id": "F016",
      "source_text": " 代回前面的链式法则中：",
      "source_text_sha256": "8d0d2765bfa1684e845413089e5b4395894bf10ceb568e642613b9f09e21c356",
      "start_byte": 2925
    },
    {
      "end_byte": 3176,
      "focus_id": "F017",
      "source_text": " 最后，将这个结果填入最初的加速度展开式里：",
      "source_text_sha256": "31e36c2a63939bcbac47efe990897e1584a8092fd27dd15646522ddc52beb8af",
      "start_byte": 3112
    }
  ],
