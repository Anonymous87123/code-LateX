    1:         self.assertEqual(2, first.returncode, first.stderr)
    1:         initial = json.loads(first.stdout)
    1:         request = initial["warning_review_request"]
    1:         fingerprint = request["warnings"][0]["warning_fingerprint"]
    1:         command = [
    1:             sys.executable,
    1:             str(SCRIPT),
    1:             str(before),
    1:             str(after),
    1:             "--format",
    1:             "json",
    1:             "--propose-warning-resolution",
    1:             f"{fingerprint}=人工建议恢复原句中的模态范围以保留表达功能",
    1:             "--warning-review-request-sha256",
    1:             request["request_sha256"],
               ]
       
    2:         proposed = subprocess.run(
    1:             command,
    1:             check=False,
    1:             capture_output=True,
    1:             text=True,
    1:             encoding="utf-8",
    1:             env={**os.environ, "PYTHONUTF8": "1"},
               )
    1:         self.assertEqual(2, proposed.returncode, proposed.stderr)
    1:         payload = json.loads(proposed.stdout)
    1:         self.assertEqual("REVIEW", payload["delivery_gate_status"])
    1:         proposal = payload["warning_proposal_state"]
    1:         self.assertEqual("UNVERIFIED_CALLER_PROPOSAL", proposal["proposal_source"])
    1:         self.assertFalse(proposal["reviewer_identifier_collected"])
    1:         self.assertFalse(proposal["identity_verified"])
    1:         self.assertFalse(proposal["review_clearance_granted"])
       
    2:         retired = subprocess.run(
