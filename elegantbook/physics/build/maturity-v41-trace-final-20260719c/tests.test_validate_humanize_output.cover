    1:     def test_keep_reason_requires_specific_chinese_reason(self) -> None:
    1:         valid = {"LEX-COACH-01"}
    2:         with self.assertRaises(ValueError):
    1:             validator._parse_keep_reasons(["LEX-COACH-01=保留"], valid)
    2:         with self.assertRaises(ValueError):
    1:             validator._parse_keep_reasons(["LEX-COACH-01=确认保留"], valid)
