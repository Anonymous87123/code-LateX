   89:         after_block = "".join(after_lines[after_start:after_end])
   89:         record = {
   89:             "ordinal": ordinal,
   89:             "operation": tag.upper(),
   89:             "before": {
   89:                 "start_line": before_start + 1 if before_end > before_start else None,
   89:                 "end_line": before_end if before_end > before_start else None,
   89:                 "line_count": before_end - before_start,
   89:                 "han_chars": len(re.findall(r"[\u3400-\u9fff]", before_block)),
   89:                 "sha256": _sha256(before_block.encode("utf-8")),
                   },
   89:             "after": {
   89:                 "start_line": after_start + 1 if after_end > after_start else None,
   89:                 "end_line": after_end if after_end > after_start else None,
   89:                 "line_count": after_end - after_start,
   89:                 "han_chars": len(re.findall(r"[\u3400-\u9fff]", after_block)),
   89:                 "sha256": _sha256(after_block.encode("utf-8")),
                   },
               }
  267:         record["change_id"] = "QCH-" + _sha256(
   89:             _canonical_json_bytes(record)
   89:         )[:20]
   89:         records.append(record)
   78:     return records
       
       
