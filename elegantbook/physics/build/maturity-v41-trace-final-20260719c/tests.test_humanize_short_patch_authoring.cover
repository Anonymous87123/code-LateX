    1:     def test_finalize_detects_policy_change_during_execution(self) -> None:
    1:         draft_path, payload = self.create()
    1:         self.resolve_all_high_with_hunks(payload)
    1:         self.write_payload(draft_path, payload)
    1:         original = authoring.current_policy_hashes
    1:         calls = 0
       
    1:         def drifting_policy() -> dict[str, str]:
                   nonlocal calls
    2:             calls += 1
    2:             value = original()
    2:             if calls > 1:
    1:                 value["scanner_sha256"] = "f" * 64
    2:             return value
       
    2:         with mock.patch.object(authoring, "current_policy_hashes", side_effect=drifting_policy):
    2:             with self.assertRaisesRegex(authoring.AuthoringError, "POLICY_CHANGED_DURING_FINALIZE"):
    2:                 authoring.finalize_scaffold(
    1:                     self.source, draft_path, self.root / "policy-race-selection.json"
                       )
       
