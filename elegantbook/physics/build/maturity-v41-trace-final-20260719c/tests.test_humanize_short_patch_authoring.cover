    1:         self.assertEqual("humanize-short-patch-selection-authoring/v3", payload["schema_version"])
    1:         self.assertEqual(builder.sha256(self.source.read_bytes()), payload["source"]["sha256"])
    1:         self.assertEqual("tex", payload["source"]["document_format"])
    1:         self.assertEqual("AUTO", payload["source"]["scan_scene"])
    1:         self.assertEqual("COURSE", payload["configuration"]["scene"])
    1:         self.assertEqual("DOCUMENT", payload["configuration"]["source_kind"])
    1:         self.assertEqual(authoring.current_policy_hashes(), payload["policy_hashes"])
    1:         self.assertEqual("NONE", payload["configuration"]["span_suggestion_mode"])
    1:         self.assertEqual([], payload["span_suggestions"])
    1:         self.assertGreaterEqual(len(payload["high_findings"]), 2)
    2:         candidate_ids = {
    2:             item["finding_id"]
    4:             for item in payload["high_findings"]
    2:             if item["role"] == "CANDIDATE"
               }
    2:         self.assertEqual(
    1:             candidate_ids,
    3:             {item["finding_id"] for item in payload["lexical_resolutions"]},
               )
    2:         self.assertTrue(
    4:             all(item["decision"] == "PENDING" for item in payload["lexical_resolutions"])
               )
    2:         self.assertEqual(
    1:             len(payload["high_findings"]),
    4:             sum(len(span["finding_ids"]) for span in payload["spans"]),
               )
    1:         self.assertEqual(payload, json.loads(path.read_text(encoding="utf-8")))
    1:         self.assertFalse(payload["completion_claim_allowed"])
       
    1:     def test_finalize_expands_single_span_registry_to_strict_v2_selection(self) -> None:
