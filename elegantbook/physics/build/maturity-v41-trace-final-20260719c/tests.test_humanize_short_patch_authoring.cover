    1: def load_module(name: str, path: Path):
    2:     spec = importlib.util.spec_from_file_location(name, path)
    2:     assert spec is not None and spec.loader is not None
    2:     module = importlib.util.module_from_spec(spec)
    2:     sys.modules[name] = module
    2:     spec.loader.exec_module(module)
    2:     return module
       
       
    1: builder = load_module("authoring_test_builder", BUILDER_PATH)
    1: authoring = load_module("scaffold_humanize_short_patch", AUTHORING_PATH)
       
       
    2: class HumanizeShortPatchAuthoringTests(unittest.TestCase):
    1:     def setUp(self) -> None:
   18:         self.temp = tempfile.TemporaryDirectory()
   18:         self.root = Path(self.temp.name)
   18:         self.source = self.root / "source.tex"
   18:         self.source_text = (
   18:             "值得注意的是，先读题。\n"
                   "若条件冲突，保留原句。\n"
                   "这个结论具有重要意义。\n"
               )
   18:         self.source.write_text(self.source_text, encoding="utf-8")
       
    1:     def tearDown(self) -> None:
   18:         self.temp.cleanup()
       
    1:     def create(self, name: str = "selection.authoring.json") -> tuple[Path, dict]:
   14:         output = self.root / name
   28:         payload = authoring.create_scaffold(
   14:             self.source,
   14:             output,
   14:             requested_output="PATCH",
   14:             scene="COURSE",
   14:             intensity="BALANCED",
   14:             source_kind="DOCUMENT",
   14:             protected_terms=[],
   14:             span_suggestion_mode="NONE",
               )
   14:         return output, payload
       
    2:     @staticmethod
    2:     def resolve_all_high_with_hunks(payload: dict) -> None:
   22:         span_by_finding = {
   48:             finding_id: span["span_id"]
   48:             for span in payload["spans"]
   48:             for finding_id in span["finding_ids"]
               }
   33:         for index, resolution in enumerate(payload["lexical_resolutions"], start=1):
   22:             hunk_id = f"H{index:03d}"
   44:             resolution.update(
   22:                 {"decision": "HUNK", "hunk_id": hunk_id, "reason": None}
                   )
   44:             payload["hunks"].append(
   22:                 {
   22:                     "hunk_id": hunk_id,
   22:                     "span_id": span_by_finding[resolution["finding_id"]],
   22:                     "decision": "DELETE_STYLE_SHELL",
   22:                     "replacement": "",
   22:                     "reason": "删除该处未增加对象或判断条件的高风险句壳。",
                       }
                   )
       
    1:     def write_payload(self, path: Path, payload: dict) -> None:
   34:         path.write_text(
   17:             json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True) + "\n",
   17:             encoding="utf-8",
               )
       
    1:     def test_create_scaffold_freezes_source_policy_and_all_auto_high(self) -> None:
