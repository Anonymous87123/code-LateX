    1: def build_parser() -> argparse.ArgumentParser:
           parser = argparse.ArgumentParser(
               description="Extract static detector-report annotations as style-editing scope hints."
           )
           parser.add_argument("report", type=Path, help="Local HTML detector report")
           parser.add_argument(
               "--source",
               type=Path,
               help="Optional source document used for unique exact normalized mapping",
           )
           parser.add_argument(
               "--format",
               choices=("json",),
               default="json",
               help="Output format (currently only json)",
           )
           parser.add_argument("--output", type=Path, help="Optional path for the JSON result")
           return parser
       
       
    1: def main(argv: Sequence[str] | None = None) -> int:
           args = build_parser().parse_args(argv)
           if hasattr(sys.stdout, "reconfigure"):
               sys.stdout.reconfigure(encoding="utf-8")
           try:
               payload = analyze_report(args.report, args.source)
           except (OSError, UnicodeError) as error:
               payload = {
                   "schema_version": SCHEMA_VERSION,
                   "operation": "detector_report_scope_extraction",
                   "status": "REVIEW",
                   "exit_code": 2,
                   "report_path": str(args.report.resolve()),
                   "report_sha256": None,
                   "source_path": str(args.source.resolve()) if args.source else None,
                   "source_sha256": None,
                   "coverage": {
                       "total_fragments": 0,
                       "uniquely_mapped": 0,
                       "missing": 0,
                       "ambiguous": 0,
                       "not_mapped_no_source": 0,
                       "source_errors": 1,
                       "ratio": 0.0,
                   },
                   "review_reasons": [
                       {
                           "code": "INPUT_READ_FAILED",
                           "message": str(error),
                       }
                   ],
                   "fragments": [],
               }
           rendered = json.dumps(payload, ensure_ascii=False, indent=2) + "\n"
           if args.output:
               args.output.parent.mkdir(parents=True, exist_ok=True)
               args.output.write_text(rendered, encoding="utf-8")
           sys.stdout.write(rendered)
           return int(payload["exit_code"])
       
       
    1: if __name__ == "__main__":
           raise SystemExit(main())
