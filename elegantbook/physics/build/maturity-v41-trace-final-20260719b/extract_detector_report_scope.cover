    1: def _all_occurrences(text: str, query: str) -> list[int]:
   10:     positions: list[int] = []
   10:     cursor = 0
   20:     while query and cursor <= len(text) - len(query):
   18:         position = text.find(query, cursor)
   18:         if position < 0:
    8:             break
   10:         positions.append(position)
   10:         cursor = position + 1
   10:     return positions
       
       
    1: def _line_column(text: str, offset: int) -> tuple[int, int]:
   10:     line = text.count("\n", 0, offset) + 1
   10:     previous_break = text.rfind("\n", 0, offset)
   10:     return line, offset - previous_break
       
       
    1: def _map_fragments(fragments: list[dict[str, Any]], source_text: str) -> None:
