  234:     for original_offset, raw_character in enumerate(text):
  452:         for character in unicodedata.normalize("NFKC", raw_character):
  226:             if character.isspace():
   76:                 if output and output[-1] != " ":
   76:                     pending_space = original_offset
   76:                 continue
  150:             if pending_space is not None:
   16:                 output.append(" ")
   16:                 offsets.append(pending_space)
   16:                 pending_space = None
  150:             output.append(character)
  150:             offsets.append(original_offset)
    8:     return "".join(output), offsets
       
       
    1: def _marker_triggers(tag: str, attrs: Sequence[tuple[str, str | None]]) -> list[str]:
   34:     triggers: list[str] = []
   34:     if tag == "mark":
   10:         triggers.append("tag:mark")
   42:     for raw_name, raw_value in attrs:
    8:         name = raw_name.casefold()
    8:         value = (raw_value or "").casefold()
    8:         if name in {"class", "id"} and any(keyword in value for keyword in MARKER_KEYWORDS):
                   triggers.append(f"{name}={raw_value or ''}")
    8:         elif name.startswith("data-") and any(
                   keyword in name or keyword in value for keyword in MARKER_KEYWORDS
               ):
                   triggers.append(f"{raw_name}={raw_value or ''}")
   34:     return list(dict.fromkeys(triggers))
       
       
    2: class DetectorScopeHTMLParser(HTMLParser):
