    1: def _declared_html_encoding(raw: bytes) -> str | None:
    8:     header = raw[:4096].decode("latin-1", errors="ignore")
   16:     match = re.search(
    8:         r"(?is)<meta[^>]+charset\s*=\s*['\"]?\s*([A-Za-z0-9._-]+)",
    8:         header,
