  208:     return value
       
       
    1: def _locate(source: bytes, text: str, start_byte: Any, label: str) -> tuple[int, int]:
  231:     needle = _required_string(text, f"{label}.source_text").encode("utf-8")
  231:     if start_byte is None:
   23:         positions: list[int] = []
   23:         cursor = 0
   46:         while True:
   46:             found = source.find(needle, cursor)
   46:             if found < 0:
   23:                 break
   23:             positions.append(found)
   23:             cursor = found + 1
   23:         if len(positions) != 1:
                   raise CoverageError(
                       f"{label}.source_text is missing or ambiguous; "
                       f"candidate_start_bytes={positions}"
                   )
   23:         start = positions[0]
           else:
  208:         start = _integer(start_byte, f"{label}.start_byte")
  208:         if source[start : start + len(needle)] != needle:
                   raise CoverageError(f"{label}.start_byte does not match source_text")
  231:     return start, start + len(needle)
       
       
    1: def _char_to_byte_offsets(text: str, offsets: set[int]) -> dict[int, int]:
  152:     result: dict[int, int] = {}
  152:     byte_offset = 0
 6190:     for index, character in enumerate(text):
 6038:         if index in offsets:
  460:             result[index] = byte_offset
 6038:         byte_offset += len(character.encode("utf-8"))
  152:     if len(text) in offsets:
               result[len(text)] = byte_offset
  152:     if set(result) != offsets:
               raise CoverageError("scanner returned an invalid character offset")
  152:     return result
       
       
