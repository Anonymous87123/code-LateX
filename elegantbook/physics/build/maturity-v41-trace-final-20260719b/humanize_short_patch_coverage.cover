    1: def _canonical_json(value: Any) -> bytes:
 2448:     return json.dumps(
  816:         value, ensure_ascii=False, sort_keys=True, separators=(",", ":")
  816:     ).encode("utf-8")
       
       
    1: def _sha256(raw: bytes) -> str:
