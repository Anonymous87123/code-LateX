 1592:     return value
       
       
    1: def _specific_reason(value: Any, label: str) -> str:
  238:     reason = _required_string(value, label).strip()
  238:     normalized = re.sub(r"[\s。！？!?.,，;；:：]+$", "", reason).strip().casefold()
  238:     if normalized in GENERIC_REASONS:
    1:         raise CoverageError(f"{label} is generic or unfinished")
  237:     return reason
       
       
    1: def _identifier(value: Any, label: str, *, signal: bool = False) -> str:
