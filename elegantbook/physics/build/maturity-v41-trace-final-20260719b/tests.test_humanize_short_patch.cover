    2:         with mock.patch.object(applicator.subprocess, "run", side_effect=wrong_hash):
    2:             with self.assertRaisesRegex(applicator.ShortPatchError, "EVIDENCE_HASH_MISMATCH"):
    1:                 applicator.apply_patch(self.source, bundle_path, self.root / "wrong-hash-output")
    1:         self.assertFalse((self.root / "wrong-hash-output").exists())
       
    1:         def mechanical_fail(argv, **_kwargs):
    1:             before = Path(argv[2]).read_bytes()
    1:             after = Path(argv[3]).read_bytes()
    2:             return subprocess.CompletedProcess(
    1:                 argv,
    1:                 2,
