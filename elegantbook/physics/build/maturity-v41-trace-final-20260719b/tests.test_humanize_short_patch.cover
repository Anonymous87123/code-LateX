    1: def load_module(name: str, path: Path):
    3:     spec = importlib.util.spec_from_file_location(name, path)
    3:     assert spec is not None and spec.loader is not None
    3:     module = importlib.util.module_from_spec(spec)
    3:     sys.modules[name] = module
    3:     spec.loader.exec_module(module)
    3:     return module
       
       
    1: builder = load_module("build_humanize_short_patch", BUILDER_PATH)
    1: applicator = load_module("apply_humanize_short_patch", APPLICATOR_PATH)
    1: verifier = load_module("verify_humanize_short_patch", VERIFIER_PATH)
       
       
