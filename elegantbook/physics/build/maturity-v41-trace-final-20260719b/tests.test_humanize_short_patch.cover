    1:         bundle_path, _bundle = self.build()
       
    1:         def wrong_hash(argv, **_kwargs):
    1:             after = Path(argv[3]).read_bytes()
    2:             return subprocess.CompletedProcess(
    1:                 argv,
    1:                 2,
    1:                 stdout=self.fake_validator_payload(b"wrong-before", after),
    1:                 stderr=b"",
