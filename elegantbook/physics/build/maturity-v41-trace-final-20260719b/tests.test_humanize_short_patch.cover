    1:     def test_validator_reads_frozen_source_snapshot_not_live_source_path(self) -> None:
    1:         bundle_path, _bundle = self.build()
    1:         original = self.source.read_bytes()
    1:         observed: dict[str, Path] = {}
       
    1:         def fake_run(argv, **_kwargs):
    1:             before_path = Path(argv[2])
    1:             after_path = Path(argv[3])
    1:             observed["before"] = before_path
    1:             self.assertNotEqual(self.source.resolve(), before_path.resolve())
    1:             self.assertEqual(original, before_path.read_bytes())
    2:             return subprocess.CompletedProcess(
    1:                 argv,
    1:                 2,
    1:                 stdout=self.fake_validator_payload(before_path.read_bytes(), after_path.read_bytes()),
    1:                 stderr=b"",
                   )
       
    2:         with mock.patch.object(applicator.subprocess, "run", side_effect=fake_run):
    1:             applicator.apply_patch(self.source, bundle_path, self.root / "snapshot-output")
    1:         self.assertIn("before", observed)
    1:         self.assertTrue((self.root / "snapshot-output" / "source.snapshot.bin").is_file())
       
