    1:     def write_spec(self, payload: dict | None = None, name: str = "selection.json") -> Path:
   56:         path = self.root / name
  112:         path.write_text(
   56:             json.dumps(payload or self.valid_spec(), ensure_ascii=False, indent=2),
   56:             encoding="utf-8",
               )
   56:         return path
       
    1:     def build(self, payload: dict | None = None, name: str = "patch.json") -> tuple[Path, dict]:
   40:         spec = self.write_spec(payload)
   40:         output = self.root / name
   40:         result = builder.build_bundle(self.source, spec, output)
   27:         return output, result
       
    2:     @staticmethod
    2:     def refresh_evidence_manifest(output: Path, artifact_name: str) -> None:
    8:         manifest_path = output / "evidence-manifest.json"
    8:         manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    8:         raw = (output / artifact_name).read_bytes()
   35:         for entry in manifest["artifacts"]:
   35:             if entry["path"] == artifact_name:
    8:                 entry["size"] = len(raw)
    8:                 entry["sha256"] = builder.sha256(raw)
    8:                 break
               else:
                   raise AssertionError(f"artifact not found in manifest: {artifact_name}")
    8:         manifest["manifest_sha256"] = verifier._manifest_hash(manifest)
   16:         manifest_path.write_text(
    8:             json.dumps(manifest, ensure_ascii=False, indent=2, sort_keys=True) + "\n",
    8:             encoding="utf-8",
               )
       
