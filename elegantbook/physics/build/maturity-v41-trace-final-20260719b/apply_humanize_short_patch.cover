   31:         command,
   31:         stdin=subprocess.DEVNULL,
   31:         stdout=subprocess.PIPE,
   31:         stderr=subprocess.PIPE,
   31:         shell=False,
   31:         check=False,
           )
   31:     if process.stderr:
               raise ShortPatchError("UNIFIED_VALIDATOR_STDERR_NONEMPTY")
   31:     try:
   31:         payload = short_patch.strict_json_bytes(process.stdout, "validator output")
           except ShortPatchError as error:
               raise ShortPatchError("UNIFIED_VALIDATOR_OUTPUT_INVALID") from error
   31:     if not isinstance(payload, dict):
               raise ShortPatchError("UNIFIED_VALIDATOR_OUTPUT_INVALID")
   31:     observed_exit = process.returncode
   31:     recorded_exit = payload.get("exit_code")
   31:     delivery = payload.get("delivery_gate_status")
   31:     hard_layer = payload.get("hard_invariant_layer_status")
   31:     mechanical = payload.get("mechanical_validation_status")
   31:     evidence = payload.get("evidence")
           if (
   31:         observed_exit not in {0, 1, 2}
   31:         or isinstance(recorded_exit, bool)
   31:         or not isinstance(recorded_exit, int)
   31:         or recorded_exit != observed_exit
   31:         or delivery not in {"PASS", "REVIEW", "FAIL"}
   31:         or mechanical not in {"PASS", "REVIEW", "FAIL"}
   31:         or hard_layer not in {"PASS", "FAIL"}
   31:         or not isinstance(evidence, dict)
           ):
               raise ShortPatchError("UNIFIED_VALIDATOR_RESULT_INCONSISTENT")
   31:     expected = {"PASS": 0, "REVIEW": 2, "FAIL": 1}
   31:     if expected[delivery] != observed_exit:
               raise ShortPatchError("UNIFIED_VALIDATOR_RESULT_INCONSISTENT")
   31:     if (mechanical == "FAIL" or hard_layer == "FAIL") and (
    3:         delivery != "FAIL" or observed_exit != 1
           ):
    1:         raise ShortPatchError("UNIFIED_VALIDATOR_RESULT_INCONSISTENT")
   30:     expected_before = str(bundle["source_sha256"])
   30:     expected_after = short_patch.sha256(candidate_path.read_bytes())
           if (
   30:         evidence.get("before_sha256") != expected_before
   29:         or evidence.get("after_sha256") != expected_after
           ):
    1:         raise ShortPatchError("UNIFIED_VALIDATOR_EVIDENCE_HASH_MISMATCH")
   29:     if observed_exit == 1 or delivery == "FAIL" or hard_layer == "FAIL":
    2:         raise ShortPatchError("UNIFIED_VALIDATOR_FAILED")
   27:     return payload, process.stdout
       
       
