    1: def _candidate_name(source_path: Path) -> str:
   23:     suffix = source_path.suffix.casefold()
   23:     if suffix == ".ltx":
    1:         return "candidate.review.tex"
   22:     return "candidate.review" + (suffix if suffix in {".md", ".tex", ".txt"} else ".txt")
       
       
    1: def _apply_bytes(source: bytes, bundle: dict[str, Any]) -> bytes:
   39:     pieces: list[bytes] = []
   39:     cursor = 0
  178:     for hunk in bundle["hunks"]:
  139:         start = int(hunk["start_byte"])
  139:         end = int(hunk["end_byte"])
  139:         pieces.append(source[cursor:start])
  139:         pieces.append(str(hunk["replacement"]).encode("utf-8"))
  139:         cursor = end
   39:     pieces.append(source[cursor:])
   39:     return b"".join(pieces)
       
       
    1: def _diff(source: bytes, candidate: bytes) -> bytes:
   35:     before = source.decode("utf-8").splitlines(keepends=True)
   35:     after = candidate.decode("utf-8").splitlines(keepends=True)
   70:     rendered = "".join(
   70:         difflib.unified_diff(
   35:             before,
   35:             after,
   35:             fromfile="source",
   35:             tofile="candidate",
   35:             lineterm="\n",
               )
           )
   35:     return rendered.encode("utf-8")
       
       
    1: def _preformatted(value: Any) -> str:
  199:     return "<pre>" + html.escape(str(value), quote=True) + "</pre>"
       
       
    1: def _inline_escaped(value: Any) -> str:
  113:     return (
  113:         html.escape(str(value), quote=True)
  113:         .replace("`", "&#96;")
  113:         .replace("\r", "&#13;")
  113:         .replace("\n", "&#10;")
           )
       
       
