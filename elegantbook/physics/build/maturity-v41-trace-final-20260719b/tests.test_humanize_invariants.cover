    4: SCRIPT = Path(
    2:     os.environ.get(
    1:         "HUMANIZE_SKILL_DIR",
    1:         Path.home() / ".codex" / "skills" / "humanize-academic-chinese",
           )
    2: ) / "scripts" / "check_humanize_invariants.py"
       
    1: SPEC = importlib.util.spec_from_file_location("check_humanize_invariants", SCRIPT)
    1: assert SPEC is not None and SPEC.loader is not None
    1: invariants = importlib.util.module_from_spec(SPEC)
    1: sys.modules[SPEC.name] = invariants
    1: SPEC.loader.exec_module(invariants)
       
       
    1: def fixture(name: str) -> str:
   10:     return (FIXTURES / name).read_text(encoding="utf-8")
       
       
    1: def codes(result: object, field: str) -> set[str]:
  184:     return {item.code for item in getattr(result, field)}
       
       
    2: class HumanizeInvariantTests(unittest.TestCase):
    1:     def test_safe_style_rewrite_passes_without_warning(self) -> None:
