    1:     def test_fragment_mode_allows_only_unchanged_boundary_imbalance(self) -> None:
    1:         before = "\\begin{document}\n值得注意的是，结论保持不变。\n"
    1:         after = "\\begin{document}\n结论保持不变。\n"
    2:         whole_document = invariants.check_documents(
    1:             before, after, document_format="tex"
               )
    2:         fragment = invariants.check_documents(
    1:             before,
    1:             after,
    1:             document_format="tex",
    1:             fragment_mode=True,
               )
       
    1:         self.assertIn("LATEX_ENVIRONMENT_UNBALANCED", codes(whole_document, "errors"))
    1:         self.assertNotIn("LATEX_ENVIRONMENT_UNBALANCED", codes(fragment, "errors"))
    1:         self.assertFalse(fragment.errors)
    1:         self.assertEqual("FRAGMENT", fragment.evidence["document_scope"])
       
    2:         drifted = invariants.check_documents(
    1:             before,
    1:             "结论保持不变。\n",
    1:             document_format="tex",
    1:             fragment_mode=True,
               )
    1:         self.assertIn("LATEX_ENVIRONMENT_ORDER_CHANGED", codes(drifted, "errors"))
       
