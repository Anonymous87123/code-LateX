    1: def load_lexicon(path: str | Path = DEFAULT_LEXICON) -> dict[str, Any]:
           """Load and minimally validate the lexical signal contract."""
  308:     lexicon_path = Path(path)
  616:     with lexicon_path.open("r", encoding="utf-8") as handle:
  308:         data = json.load(handle)
       
  308:     if not isinstance(data.get("signals"), list) or not data["signals"]:
               raise ValueError("lexicon must contain a non-empty signals list")
       
