 8932:         signal_id = signal["id"]
 8932:         if signal_id in seen:
                   raise ValueError(f"duplicate signal id: {signal_id}")
 8932:         seen.add(signal_id)
 8932:         if signal["action"] not in {"KEEP", "DELETE", "REWRITE", "REVIEW"}:
                   raise ValueError(f"invalid action for {signal_id}: {signal['action']}")
 8932:         threshold = signal["threshold"]
 8932:         if threshold.get("window") not in {"document", "paragraph", "sentence", "line"}:
                   raise ValueError(f"invalid threshold window for {signal_id}")
 8932:         if int(threshold.get("min_occurrences", 0)) < 1:
                   raise ValueError(f"invalid min_occurrences for {signal_id}")
23716:         for pattern in signal["regex"]:
14784:             re.compile(pattern, re.IGNORECASE | re.MULTILINE)
17556:         for exclusion in signal["exclusions"]:
 8624:             if set(exclusion) != {"scope", "regex", "reason"}:
                       raise ValueError(f"invalid exclusion contract for {signal_id}")
 8624:             re.compile(exclusion["regex"], re.IGNORECASE | re.MULTILINE)
  308:     return data
       
       
    1: def _markdown_fence_spans(text: str) -> list[tuple[int, int, str]]:
  950:     opening_re = re.compile(
  475:         r"(?m)^[ \t]{0,3}(?P<fence>`{3,}|~{3,})[^\n]*(?:\n|$)"
           )
  475:     spans: list[tuple[int, int, str]] = []
  475:     cursor = 0
  480:     while cursor < len(text):
  475:         opening = opening_re.search(text, cursor)
  475:         if opening is None:
  470:             break
    5:         fence = opening.group("fence")
   10:         closing_re = re.compile(
    5:             rf"(?m)^[ \t]{{0,3}}{re.escape(fence[0])}{{{len(fence)},}}[ \t]*(?:\n|$)"
               )
    5:         closing = closing_re.search(text, opening.end())
    5:         end = closing.end() if closing is not None else len(text)
    5:         spans.append((opening.start(), end, "markdown-fence"))
    5:         cursor = end
  475:     return spans
       
       
    4: def _raw_protected_spans(
    1:     text: str,
    2:     document_format: str = "markdown",
    1: ) -> list[tuple[int, int, str]]:
  475:     if document_format not in {"markdown", "tex"}:
               raise ValueError("document_format must be 'markdown' or 'tex'")
  475:     patterns = [
  475:         (
  475:             "latex-verbatim-or-math-environment",
  950:             re.compile(
  475:                 r"(?is)\\begin\{(equation\*?|align\*?|alignat\*?|alignedat|gather\*?|multline\*?|"
                       r"displaymath|math|verbatim\*?|lstlisting|minted)\}.*?\\end\{\1\}"
                   ),
               ),
  475:         (
  475:             "latex-exam-or-formal-statement-environment",
  950:             re.compile(
  475:                 r"(?is)\\begin\{(example\*?|exercise\*?|problem\*?|question\*?|"
                       r"theorem\*?|lemma\*?|proposition\*?|corollary\*?|definition\*?)\}"
                       r".*?\\end\{\1\}"
                   ),
               ),
  475:         ("display-math", re.compile(r"(?s)(?<!\\)\$\$.*?(?<!\\)\$\$|\\\[.*?\\\]")),
  475:         ("inline-math", re.compile(r"(?s)\\\(.*?\\\)|(?<!\\)\$(?!\$)(?:\\.|[^$\n])+?(?<!\\)\$")),
  475:         ("inline-code", re.compile(r"(?<!`)`[^`\n]+`(?!`)")),
  475:         ("markdown-quote", re.compile(r"(?m)^\s*>[^\n]*")),
  475:         ("chinese-double-quote", re.compile(r"“[^”\n]*”|「[^」\n]*」|『[^』\n]*』")),
  475:         ("chinese-single-quote", re.compile(r"‘[^’\n]*’")),
  475:         (
  475:             "latex-quote",
  950:             re.compile(
  475:                 r"``[^\n]*?''|\\(?:enquote|textquote)\{(?:[^{}\n]|\{[^{}\n]*\})*\}"
                   ),
               ),
  475:         ("ascii-quote", re.compile(r'(?<!\\)"[^"\n]*?(?<!\\)"')),
           ]
  475:     if document_format == "tex":
  159:         patterns.append(("latex-comment", re.compile(r"(?m)(?<!\\)%[^\n]*")))
  475:     spans = _markdown_fence_spans(text)
 5384:     for reason, pattern in patterns:
10045:         spans.extend((match.start(), match.end(), reason) for match in pattern.finditer(text))
  475:     return spans
       
       
    1: def _merge_spans(spans: Iterable[tuple[int, int, str]]) -> list[tuple[int, int, str]]:
  475:     merged: list[list[Any]] = []
  939:     for start, end, reason in sorted(spans, key=lambda item: (item[0], item[1])):
  232:         if not merged or start >= merged[-1][1]:
  232:             merged.append([start, end, {reason}])
  232:             continue
               merged[-1][1] = max(merged[-1][1], end)
               merged[-1][2].add(reason)
  707:     return [(start, end, "+".join(sorted(reasons))) for start, end, reasons in merged]
       
       
    2: class ProtectedIndex:
    1:     """Find whether an offset falls inside code, math, comments, or quotations."""
       
    1:     def __init__(self, text: str, document_format: str = "markdown") -> None:
  475:         self.spans = _merge_spans(_raw_protected_spans(text, document_format))
  707:         self.starts = [span[0] for span in self.spans]
       
    1:     def reason_at(self, offset: int) -> str | None:
               index = bisect_right(self.starts, offset) - 1
               if index >= 0:
                   start, end, reason = self.spans[index]
                   if start <= offset < end:
                       return reason
               return None
       
    1:     def reason_for_span(self, start: int, end: int) -> str | None:
  764:         index = bisect_right(self.starts, start) - 1
  764:         if index >= 0:
  356:             protected_start, protected_end, reason = self.spans[index]
  356:             if protected_start <= start and end <= protected_end:
   12:                 return reason
  752:         return None
       
       
    1: def _signal_patterns(signal: dict[str, Any]) -> list[re.Pattern[str]]:
11336:     patterns: list[re.Pattern[str]] = []
11336:     if signal["variants"]:
 8024:         variants = sorted(set(signal["variants"]), key=len, reverse=True)
90696:         patterns.append(re.compile("|".join(re.escape(item) for item in variants), re.IGNORECASE))
34008:     patterns.extend(
18434:         re.compile(pattern, re.IGNORECASE | re.MULTILINE)
41106:         for pattern in signal["regex"]
           )
11336:     return patterns
       
       
    1: def _deduplicate_matches(matches: Iterable[re.Match[str]]) -> list[tuple[int, int, str]]:
22672:     raw = sorted(
23469:         ((match.start(), match.end(), match.group(0)) for match in matches),
12133:         key=lambda item: (item[0], -(item[1] - item[0])),
           )
11336:     kept: list[tuple[int, int, str]] = []
12133:     for candidate in raw:
  797:         start, end, _ = candidate
 1756:         if any(start < old_end and end > old_start for old_start, old_end, _ in kept):
   33:             continue
  764:         kept.append(candidate)
11336:     return sorted(kept)
       
       
    1: def _bounded_span(text: str, offset: int, separators: str) -> tuple[int, int]:
 6420:     left = max((text.rfind(char, 0, offset) for char in separators), default=-1) + 1
 5778:     right_candidates = [text.find(char, offset) for char in separators]
 5778:     right_candidates = [position for position in right_candidates if position >= 0]
  642:     right = min(right_candidates) + 1 if right_candidates else len(text)
  642:     return left, right
       
       
    1: def _paragraph_span(text: str, offset: int) -> tuple[int, int]:
  286:     separators = list(re.finditer(r"(?:\r?\n\s*){2,}", text))
  286:     start = 0
  286:     end = len(text)
  445:     for separator in separators:
  264:         if separator.end() <= offset:
  159:             start = separator.end()
  105:         elif separator.start() >= offset:
  105:             end = separator.start()
  105:             break
  286:     return start, end
       
       
    1: def _scope_span(text: str, offset: int, scope: str) -> tuple[int, int]:
 1393:     if scope == "document":
  473:         return 0, len(text)
  920:     if scope == "paragraph":
  278:         return _paragraph_span(text, offset)
  642:     if scope == "sentence":
  642:         return _bounded_span(text, offset, SENTENCE_BREAKS)
           if scope == "line":
               return _bounded_span(text, offset, "\n")
           raise ValueError(f"unsupported scope: {scope}")
       
       
    1: def _scope_bounds(text: str, start: int, end: int, scope: str) -> tuple[int, int]:
  596:     if scope == "match":
               return start, end
  596:     if scope == "context":
               return max(0, start - 100), min(len(text), end + 100)
  596:     return _scope_span(text, start, scope)
       
       
    6: def _exclusion_reason(
    1:     text: str,
    1:     start: int,
    1:     end: int,
    1:     signal: dict[str, Any],
    1: ) -> str | None:
 1347:     for exclusion in signal["exclusions"]:
  596:         scope_start, scope_end = _scope_bounds(text, start, end, exclusion["scope"])
  596:         scoped = text[scope_start:scope_end]
  596:         for match in re.finditer(exclusion["regex"], scoped, re.IGNORECASE | re.MULTILINE):
    1:             absolute_start = scope_start + match.start()
    1:             absolute_end = scope_start + match.end()
    1:             if absolute_start < end and absolute_end > start:
    1:                 return exclusion["reason"]
  751:     return None
       
       
    1: def _line_column(text: str, offset: int) -> tuple[int, int]:
  576:     line = text.count("\n", 0, offset) + 1
  576:     last_break = text.rfind("\n", 0, offset)
  576:     column = offset - last_break
  576:     return line, column
       
       
    1: def _context(text: str, start: int, end: int, radius: int = 70) -> str:
  576:     snippet = text[max(0, start - radius):min(len(text), end + radius)]
  576:     return re.sub(r"\s+", " ", snippet).strip()
       
       
    1: def _window_key(text: str, offset: int, scope: str) -> tuple[int, int]:
  755:     return _scope_span(text, offset, scope)
       
       
    5: def _qualifying_counts(
    1:     text: str,
    1:     occurrences: Sequence[dict[str, Any]],
    1:     threshold: dict[str, Any],
    1: ) -> list[int]:
11336:     scope = threshold["window"]
11336:     max_chars = int(threshold.get("window_chars", 0) or 0)
11336:     distinct_scope = threshold.get("count_distinct_by")
11336:     if distinct_scope not in {None, "paragraph", "sentence", "line"}:
               raise ValueError(f"unsupported count_distinct_by: {distinct_scope}")
12087:     keys = [_window_key(text, item["start"], scope) for item in occurrences]
11336:     counts: list[int] = []
12087:     for index, occurrence in enumerate(occurrences):
  751:         key = keys[index]
 1502:         neighbors = [
 2066:             item
 2551:             for other_index, item in enumerate(occurrences)
 1049:             if keys[other_index] == key
 1017:             and (not max_chars or abs(item["start"] - occurrence["start"]) <= max_chars)
               ]
  751:         if distinct_scope:
    4:             counts.append(
    6:                 len({_window_key(text, item["start"], distinct_scope) for item in neighbors})
                   )
               else:
  749:             counts.append(len(neighbors))
11336:     return counts
       
       
