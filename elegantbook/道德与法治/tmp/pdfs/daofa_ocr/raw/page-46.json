      "bbox": [
        194.0,
        1674.0,
        702.0,
        1712.0
      ]
    },
    {
      "text": "5.人身自由不受侵犯",
      "score": 0.8415631001645868,
      "bbox": [
        195.0,
        1719.0,
        456.0,
        1751.0
      ]
    },
    {
      "text": "宪法规定：任何公民，非经人民检察院批准或者决定或者人民法院决定，并由公安机关执行，不受逮捕",
      "score": 0.9368197308934253,
